---
import Layout from "../layouts/layout.astro";
---

<Layout>
  <main class="py-14 grow">
    <div class="max-w-screen-xl mx-auto px-4 text-gray-600 md:px-8">
      <div class="max-w-lg mx-auto space-y-4 text-center">
        <h1 class="text-gray-800 text-6xl font-semibold">404</h1>
        <p class="text-gray-800 text-3xl font-semibold">Page not found</p>
        <p>Sorry, the page you're looking for doesn't exist.</p>
        <a href="/" class="inline-block mt-4 text-indigo-600 hover:underline">
          Back to home
        </a>
      </div>
    </div>
  </main>
</Layout>
